# Copy to deploy.env and fill in after first-time setup.
# deploy.env is gitignored — never commit secrets.

AWS_REGION=us-east-1

# Backend (SAM)
BACKEND_STACK_NAME=flexsim-station-console
# CORS: set to your CloudFront URL after frontend deploy (e.g. https://d111abc.cloudfront.net)
# Use * only for initial testing.
ALLOWED_ORIGIN=*

# Frontend (CloudFormation stack in infra/frontend.yaml)
FRONTEND_STACK_NAME=flexsim-station-console-frontend
# Globally unique S3 bucket name (lowercase, no spaces)
SITE_BUCKET_NAME=flexsim-station-console-site-YOUR_ACCOUNT_ID

# Filled in after first backend deploy (stack output ApiUrl)
API_URL=

# Filled in after first frontend deploy (stack outputs)
FRONTEND_URL=
CLOUDFRONT_DISTRIBUTION_ID=
FRONTEND_BUCKET=
